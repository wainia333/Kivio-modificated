{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kivio",
  "version": "2.5.1",
  "identifier": "com.zmair.kivio",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "beforeBuildCommand": "npm run build:ui",
    "devUrl": "http://localhost:5713",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kivio",
        "width": 600,
        "height": 420,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "visibleOnAllWorkspaces": true,
        "create": false,
        "skipTaskbar": true,
        "visible": false
      }
    ],
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "msi",
      "nsis"
    ],
    "externalBin": [
      "binaries/kivio-ai-helper"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    },
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
